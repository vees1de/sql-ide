        "sql_text": "SELECT\n  EXTRACT(HOUR FROM order_timestamp) AS hour,\n  AVG(EXTRACT(EPOCH FROM (\n    driverarrived_timestamp - driveraccept_timestamp\n  ))) AS avg_accept_to_arrival_seconds,\n  AVG(EXTRACT(EPOCH FROM (\n    driverdone_timestamp - driverstarttheride_timestamp\n  ))) AS avg_ride_seconds\nFROM train\nWHERE\n  status_order = 'completed'\n  AND CAST(order_timestamp AS DATE) = CAST('2026-04-02' AS DATE)\n  AND NOT driveraccept_timestamp IS NULL\n  AND NOT driverarrived_timestamp IS NULL\n  AND NOT driverstarttheride_timestamp IS NULL\n  AND NOT driverdone_timestamp IS NULL\nGROUP BY\n  hour\nORDER BY\n  hour\nLIMIT 50",
