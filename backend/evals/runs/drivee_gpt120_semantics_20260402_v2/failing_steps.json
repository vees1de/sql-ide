      "sql": "SELECT driver_id,\n       total_accepted,\n       total_not_completed,\n       (total_not_completed::numeric / NULLIF(total_accepted, 0)) AS share_not_completed\nFROM (\n    SELECT driver_id,\n           COUNT(*) FILTER (WHERE driveraccept_timestamp IS NOT NULL) AS total_accepted,\n           COUNT(*) FILTER (WHERE driveraccept_timestamp IS NOT NULL AND driverdone_timestamp IS NULL) AS total_not_completed\n    FROM train\n    WHERE order_timestamp::date = DATE '2026-04-02'\n    GROUP BY driver_id\n) sub\nWHERE total_accepted >= 20\nORDER BY share_not_completed DESC NULLS LAST\nLIMIT 10;",
