      "sql": "SELECT\n  EXTRACT(HOUR FROM order_timestamp) AS hour,\n  AVG(EXTRACT(EPOCH FROM (driverarrived_timestamp - driveraccept_timestamp))) AS avg_accept_to_arrival_seconds,\n  AVG(EXTRACT(EPOCH FROM (driverdone_timestamp - driverstarttheride_timestamp))) AS avg_ride_seconds\nFROM train\nWHERE status_order = 'completed'\n  AND order_timestamp::date = DATE '2026-04-02'\n  AND driveraccept_timestamp IS NOT NULL\n  AND driverarrived_timestamp IS NOT NULL\n  AND driverstarttheride_timestamp IS NOT NULL\n  AND driverdone_timestamp IS NOT NULL\nGROUP BY hour\nORDER BY hour;",
