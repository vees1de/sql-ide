      "sql": "SELECT DATE_TRUNC('hour', t.order_timestamp) AS hour,\n       AVG(EXTRACT(EPOCH FROM (t.driverarrived_timestamp - t.driveraccept_timestamp)) / 60) AS avg_accept_to_arrival_min,\n       AVG(EXTRACT(EPOCH FROM (t.driverdone_timestamp - t.driverstarttheride_timestamp)) / 60) AS avg_start_to_done_min\nFROM train t\nWHERE t.order_timestamp::date = DATE '2026-04-14'\n  AND t.driveraccept_timestamp IS NOT NULL\n  AND t.driverarrived_timestamp IS NOT NULL\n  AND t.driverstarttheride_timestamp IS NOT NULL\n  AND t.driverdone_timestamp IS NOT NULL\nGROUP BY hour\nORDER BY hour;",
      "execution": {
