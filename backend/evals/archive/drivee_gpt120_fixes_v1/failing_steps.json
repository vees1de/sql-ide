        "session_id": "25fec13a43b34b5aa9abb2648ca75243",
        "sql_text": "SELECT\n  DATE_TRUNC('HOUR', t.order_timestamp) AS hour,\n  AVG(\n    EXTRACT(EPOCH FROM (\n      t.driverarrived_timestamp - t.driveraccept_timestamp\n    )) / 60\n  ) AS avg_accept_to_arrival_min,\n  AVG(\n    EXTRACT(EPOCH FROM (\n      t.driverdone_timestamp - t.driverstarttheride_timestamp\n    )) / 60\n  ) AS avg_start_to_done_min\nFROM train AS t\nWHERE\n  CAST(t.order_timestamp AS DATE) = CAST('2026-04-14' AS DATE)\n  AND NOT t.driveraccept_timestamp IS NULL\n  AND NOT t.driverarrived_timestamp IS NULL\n  AND NOT t.driverstarttheride_timestamp IS NULL\n  AND NOT t.driverdone_timestamp IS NULL\nGROUP BY\n  hour\nORDER BY\n  hour\nLIMIT 50",
