      "id": "daily_store_revenue_march_2007",
      "title": "Daily revenue and payment count by store",
      "tags": ["complex", "timeseries", "comparison", "aliases"],
      "steps": [
        {
          "user": "За март 2007 покажи по дням выручку и количество платежей по магазинам. Нужен line chart.",
          "expectations": {
            "should_clarify": false,
            "sql": {
              "required_substrings": [
                "2007-03",
                "payment",
                "payment_date",
                "group by",
                "sum("
              ],
              "required_tables": [
                "payment"
              ]
            },
            "execution": {
              "should_succeed": true,
              "min_row_count": 1,
              "required_column_groups": [
                ["day"],
                ["store_id"],
                ["total_revenue"],
                ["payment_count"]
              ],
              "chart": {
                "acceptable_types": ["line"],
                "x_any_of": ["day"],
                "y_any_of": ["total_revenue"],
                "series_any_of": ["store_id"]
              }
            }
          }
        }
      ]
    },
    {
      "id": "top_categories_revenue_april_2007",
