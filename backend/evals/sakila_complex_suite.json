              "chart": {
                "acceptable_types": ["line"],
                "x_any_of": ["month", "month_bucket", "payment_month", "period"],
                "y_any_of": ["total_revenue", "revenue", "total_amount", "payment_count"]
              }
            }
          }
        }
      ]
    },
