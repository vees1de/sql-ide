{
  "suite_name": "demo_chat_text_to_sql",
  "database_name": "Demo Analytics DB",
  "query_mode": "thinking",
  "llm_model_alias": "gpt120",
  "cases": [
    {
      "id": "clarify_sales_metric",
      "title": "Ambiguous metric should trigger clarification",
      "tags": ["clarification", "understanding"],
      "steps": [
        {
          "user": "Покажи продажи по месяцам",
          "expectations": {
            "should_clarify": true,
            "clarification": {
              "question_should_contain": ["выруч", "колич", "средний"],
              "options_should_include": ["выруч", "колич", "средний"],
              "min_options": 3
            },
            "interpretation": {
              "dimensions_all_of": ["month"]
            }
          }
        }
      ]
    },
    {
      "id": "revenue_by_month",
      "title": "Revenue trend",
      "tags": ["sql", "chart", "timeseries"],
      "steps": [
        {
          "user": "Покажи выручку по месяцам за последние 3 месяца",
          "expectations": {
            "should_clarify": false,
            "interpretation": {
              "metric_any_of": ["revenue"],
              "dimensions_all_of": ["month"],
              "date_range": {
                "kind": "relative",
                "lookback_value": 3,
                "lookback_unit": "months"
              }
            },
            "sql": {
              "required_substrings": ["sum(", "group by"],
              "required_tables": ["orders"]
            },
            "execution": {
              "should_succeed": true,
              "min_row_count": 1,
              "required_column_groups": [["month", "order_date"], ["total_revenue", "revenue"]],
              "chart": {
                "acceptable_types": ["line"],
                "x_any_of": ["month", "order_date"],
                "y_any_of": ["total_revenue", "revenue"]
              }
            }
          }
        }
      ]
    },
    {
      "id": "top_cities_order_count",
      "title": "Top-N ranking should include join and limit",
      "tags": ["ranking", "limit", "join"],
      "steps": [
        {
          "user": "Покажи топ 5 городов по количеству заказов",
          "expectations": {
            "should_clarify": false,
            "interpretation": {
              "metric_any_of": ["order_count"],
              "dimensions_all_of": ["city"]
            },
            "sql": {
              "required_substrings": ["count(", "limit 5"],
              "required_tables": ["orders", "customers"]
            },
            "execution": {
              "should_succeed": true,
              "min_row_count": 1,
              "max_row_count": 5,
              "required_column_groups": [["city"], ["total_orders", "order_count", "count"]],
              "chart": {
                "acceptable_types": ["bar"],
                "x_any_of": ["city"],
                "y_any_of": ["total_orders", "order_count", "count"]
              }
            }
          }
        }
      ]
    },
    {
      "id": "follow_up_city_filter",
      "title": "Follow-up should preserve context and add filter",
      "tags": ["follow_up", "context"],
      "steps": [
        {
          "user": "Покажи выручку по месяцам за последние 2 месяца",
          "expectations": {
            "should_clarify": false,
            "interpretation": {
              "metric_any_of": ["revenue"],
              "dimensions_all_of": ["month"],
              "date_range": {
                "kind": "relative",
                "lookback_value": 2,
                "lookback_unit": "months"
              }
            }
          }
        },
        {
          "user": "Теперь только по Москве",
          "expectations": {
            "should_clarify": false,
            "interpretation": {
              "metric_any_of": ["revenue"],
              "dimensions_all_of": ["month"],
              "filters": [
                {
                  "field": "city",
                  "value_any_of": ["Moscow", "Москва"]
                }
              ],
              "date_range": {
                "kind": "relative",
                "lookback_value": 2,
                "lookback_unit": "months"
              }
            },
            "sql": {
              "required_substrings": ["sum("],
              "required_tables": ["orders", "customers"]
            },
            "execution": {
              "should_succeed": true,
              "min_row_count": 1,
              "required_column_groups": [["month", "order_date"], ["total_revenue", "revenue"]],
              "chart": {
                "acceptable_types": ["line"],
                "x_any_of": ["month", "order_date"],
                "y_any_of": ["total_revenue", "revenue"]
              }
            }
          }
        }
      ]
    },
    {
      "id": "share_by_channel",
      "title": "Explicit pie chart request",
      "tags": ["chart", "share"],
      "steps": [
        {
          "user": "Покажи долю выручки по каналам за последний месяц в виде pie chart",
          "expectations": {
            "should_clarify": false,
            "interpretation": {
              "metric_any_of": ["revenue"],
              "dimensions_all_of": ["channel"],
              "date_range": {
                "kind": "relative",
                "lookback_value": 1,
                "lookback_unit": "months"
              }
            },
            "sql": {
              "required_tables": ["orders", "campaigns"]
            },
            "execution": {
              "should_succeed": true,
              "min_row_count": 1,
              "required_column_groups": [["channel"], ["total_revenue", "revenue"]],
              "chart": {
                "acceptable_types": ["pie"],
                "x_any_of": ["channel"],
                "y_any_of": ["total_revenue", "revenue"]
              }
            }
          }
        }
      ]
    }
  ]
}
