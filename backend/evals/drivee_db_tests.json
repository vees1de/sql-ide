      "title": "Top drivers by non-completion rate",
      "tags": ["complex", "ranking", "driver", "classification"],
      "steps": [
        {
          "user": "За 14 апреля 2026 найди топ-10 водителей с самой высокой долей незавершённых поездок среди принятых. Учитывай только водителей с минимум 20 принятыми заказами.",
          "clarification_reply": "Группируй по driver_id. Принятым считай заказ с driveraccept_timestamp IS NOT NULL; завершённым — с driverdone_timestamp IS NOT NULL.",
          "expectations": {
            "should_clarify": false,
            "expected_state": "SQL_READY",
            "required_actions": ["show_run_button", "show_sql"],
            "sql": {
              "required_substrings": [
                "2026-04-14",
                "driver_id",
                "driveraccept_timestamp",
                "driverdone_timestamp",
                "limit 10"
              ],
              "required_tables": ["train"]
            },
            "execution": {
              "should_succeed": true,
              "min_row_count": 1,
              "max_row_count": 10,
              "required_column_groups": [
                ["driver_id"],
                ["accepted_orders", "accepted_count", "total_accepted"],
                ["not_completed_orders", "failed_after_accept", "not_done_orders"],
                ["non_completion_rate", "not_completed_rate", "fail_rate"]
              ],
              "chart": {
                "acceptable_types": ["bar"],
                "x_any_of": ["driver_id"],
                "y_any_of": ["non_completion_rate", "not_completed_rate", "fail_rate"]
              }
            }
          }
        }
      ]
