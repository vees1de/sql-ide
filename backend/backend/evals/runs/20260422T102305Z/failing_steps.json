      "sql": "SELECT\n  f.rating,\n  COUNT(*) FILTER (WHERE r.return_date > r.rental_date + f.rental_duration * INTERVAL '1 day') AS late_rental_count,\n  COUNT(*) AS total_rental_count,\n  COUNT(*) FILTER (WHERE r.return_date > r.rental_date + f.rental_duration * INTERVAL '1 day') * 1.0 / NULLIF(COUNT(*), 0) AS late_return_rate\nFROM rental r\nJOIN inventory i ON r.inventory_id = i.inventory_id\nJOIN film f ON i.film_id = f.film_id\nWHERE r.return_date IS NOT NULL\nGROUP BY f.rating\nORDER BY f.rating;",
      "execution": {
        "id": "41905d12ec3243638978d46caf078b1f",
        "session_id": "a971a30000db4cab86007ce6a0262dc7",
        "sql_text": "SELECT\n  f.rating,\n  COUNT(*) FILTER(WHERE\n    r.return_date > r.rental_date + f.rental_duration * INTERVAL '1 DAY') AS late_rental_count,\n  COUNT(*) AS total_rental_count,\n  COUNT(*) FILTER(WHERE\n    r.return_date > r.rental_date + f.rental_duration * INTERVAL '1 DAY') * 1.0 / NULLIF(COUNT(*), 0) AS late_return_rate\nFROM rental AS r\nJOIN inventory AS i\n  ON r.inventory_id = i.inventory_id\nJOIN film AS f\n  ON i.film_id = f.film_id\nWHERE\n  NOT r.return_date IS NULL\nGROUP BY\n  f.rating\nORDER BY\n  f.rating\nLIMIT 50",
